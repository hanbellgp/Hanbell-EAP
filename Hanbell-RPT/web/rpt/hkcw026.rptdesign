            <property name="dataSource">scriptDS</property>
            <method name="open"><![CDATA[
importPackage(Packages.cn.hanbell.efgp.rpt);
importPackage(Packages.java.lang);
ejbClient = new HKCW026Report();
ejbClient.setEJB(params["JNDIName"]);

master = ejbClient.getEntity(params["formid"]);

if(master!=null){
	detail = ejbClient.getDetail(master.getFormSerialNumber());
}

System.out.println("detail=="+detail.size());
currentRow = 0;]]></method>
            <method name="fetch"><![CDATA[if(detail==undefined || detail==null){
    return false;
}
	if (currentRow < detail.size()) {
	    dataSetRow["seq"] =currentRow+1;
	    dataSetRow["formdate"] = master.getFormdate();
	    dataSetRow["formid"] = master.getFormid();
		dataSetRow["creator"] = master.getCreator()+master.getApplyUser().getUserName();
		dataSetRow["titleDeptno"] = master.getDeptno();
		dataSetRow["titleDeptname"] = master.getDeptname();
		dataSetRow["cfmuser"] = master.getCfmuser()+master.getCfmUser().getUserName();
	
	    dataSetRow["itemno"] = detail.get(currentRow).getItemno();
	    dataSetRow["itdsc"] = detail.get(currentRow).getItdsc();
	    dataSetRow["assetno"] = detail.get(currentRow).getAssetno();
	    dataSetRow["assetname"] = detail.get(currentRow).getAssetname();
	    dataSetRow["username"] = detail.get(currentRow).getUsername()+'('+detail.get(currentRow).getDeptname()+')';
	    dataSetRow["username2"] = detail.get(currentRow).getUsername2() +'('+detail.get(currentRow).getDeptname2()+')';
	    dataSetRow["qty"] = detail.get(currentRow).getQty();
	    dataSetRow["whdsc"] = detail.get(currentRow).getWarehousena()+'->' +detail.get(currentRow).getWarehousena2();
	    currentRow++;
	    return true;
	}

return false;]]></method>
            <method name="close"><![CDATA[ejbClient = null;]]></method>
        </script-data-set>
    </data-sets>
